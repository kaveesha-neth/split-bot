# Copy this to .env and fill in your values
# NEVER commit .env to git

# From https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# From @BotFather
TELEGRAM_BOT_TOKEN=

# Optional tuning
SPLIT_SIZE_MB=1000   # size of each RAR part in MB
MIN_SIZE_MB=1000     # only process files at least this big
